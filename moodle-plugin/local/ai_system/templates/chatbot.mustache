{{! templates/chatbot.mustache }}
<div class="ai-chatbot-layout">

  <div class="ai-chatbot-sidebar">
    <div class="ai-sb-top">

      <!-- COURSE PICKER (only affects newly created sessions) -->
      {{#has_courses}}
      <div class="ai-course-picker">
        <div class="ai-course-picker-toggle" id="ai-course-toggle">
          <i class="fa fa-graduation-cap" aria-hidden="true"></i>
          <span class="ai-course-picker-label" id="ai-course-current-label">
            {{#str}} all_my_courses, local_ai_system {{/str}}
          </span>
          <i class="fa fa-chevron-down ai-course-chevron"></i>
        </div>

        <div class="ai-course-dropdown hidden" id="ai-course-dropdown">
          <div class="ai-course-option" data-course-id="0">
            <span class="ai-course-option-label">{{#str}} all_my_courses, local_ai_system {{/str}}</span>
            <i class="fa fa-check ai-course-check"></i>
          </div>
          {{#course_options}}
            <div class="ai-course-option" data-course-id="{{id}}">
              <span class="ai-course-option-label">{{fullname}}</span>
              <i class="fa fa-check ai-course-check"></i>
            </div>
          {{/course_options}}
        </div>
      </div>
      {{/has_courses}}

      <button class="ai-chatbot-new-session ai-sb-new">
        <i class="fa fa-edit" aria-hidden="true"></i>
        {{#str}} new_session, local_ai_system {{/str}}
      </button>
      <div class="ai-sb-archive" id="ai-archive-toggle">
        <i class="fa fa-archive" aria-hidden="true"></i>
        {{#str}} archive, local_ai_system {{/str}}
        <i class="fa fa-chevron-down ai-archive-chevron" style="margin-left:auto;font-size:11px;"></i>
      </div>

      <!-- ARCHIVE DROPDOWN -->
      <div class="ai-archive-dropdown hidden" id="ai-archive-dropdown">
        {{#archived_sessions}}
          <div class="ai-session-item ai-session-archived" data-session-id="{{session_id}}" data-language="{{language}}">
            <span class="ai-session-lang-badge" data-language="{{language}}">{{language}}</span>
            <span class="ai-session-title">{{title}}</span>
            <button class="ai-session-menu-btn" data-session-id="{{session_id}}" aria-label="Session menu">
              <i class="fa fa-ellipsis-v"></i>
            </button>
            <div class="ai-session-dropdown hidden" data-session-id="{{session_id}}">
              <div class="ai-dropdown-item ai-action-dearchive" data-session-id="{{session_id}}">
                <i class="fa fa-inbox"></i>
                {{#str}} dearchive_chat, local_ai_system {{/str}}
              </div>
              <div class="ai-dropdown-item ai-dropdown-danger ai-action-delete" data-session-id="{{session_id}}">
                <i class="fa fa-trash"></i>
                {{#str}} delete_chat, local_ai_system {{/str}}
              </div>
            </div>
          </div>
        {{/archived_sessions}}
        {{^archived_sessions}}
          <div class="ai-archive-empty">{{#str}} archive_empty, local_ai_system {{/str}}</div>
        {{/archived_sessions}}
      </div>
    </div>

    <div class="ai-sb-divider"></div>

    <div class="ai-sb-chats">
      {{#sessions}}
        <div class="ai-session-item" data-session-id="{{session_id}}" data-language="{{language}}">
          <span class="ai-session-lang-badge" data-language="{{language}}">{{language}}</span>
          <span class="ai-session-title">{{title}}</span>
          <button class="ai-session-menu-btn" data-session-id="{{session_id}}" aria-label="Session menu">
            <i class="fa fa-ellipsis-v"></i>
          </button>
          <div class="ai-session-dropdown hidden" data-session-id="{{session_id}}">
            <div class="ai-dropdown-item ai-action-archive" data-session-id="{{session_id}}">
              <i class="fa fa-archive"></i>
              {{#str}} archive_chat, local_ai_system {{/str}}
            </div>
            <div class="ai-dropdown-item ai-action-rename" data-session-id="{{session_id}}">
              <i class="fa fa-pencil"></i>
              {{#str}} rename_chat, local_ai_system {{/str}}
            </div>
            <div class="ai-dropdown-item ai-dropdown-danger ai-action-delete" data-session-id="{{session_id}}">
              <i class="fa fa-trash"></i>
              {{#str}} delete_chat, local_ai_system {{/str}}
            </div>
          </div>
        </div>
      {{/sessions}}
    </div>
  </div>

  <div id="ai-chatbot" class="ai-chatbot-container" data-session-id="{{session_id}}">
    <div class="ai-chatbot-header">
      <span class="ai-chat-title" id="ai-chat-title">
        {{#str}} chatbot_title, local_ai_system {{/str}}
      </span>

      <!-- LANGUAGE PICKER (переключает отображение текущего чата) -->
      <div class="ai-language-picker" id="ai-language-picker">
        <div class="ai-language-picker-toggle" id="ai-language-toggle">
          <i class="fa fa-language" aria-hidden="true"></i>
          <span class="ai-language-picker-label" id="ai-language-current-label">
            {{#str}} language_original, local_ai_system {{/str}}
          </span>
          <i class="fa fa-chevron-down ai-language-chevron"></i>
        </div>

        <div class="ai-language-dropdown hidden" id="ai-language-dropdown">
          <div class="ai-language-option selected" data-language="">
            <span class="ai-language-option-label">{{#str}} language_original, local_ai_system {{/str}}</span>
            <i class="fa fa-check ai-language-check"></i>
          </div>
          <div class="ai-language-option" data-language="en">
            <span class="ai-language-option-label">English</span>
            <i class="fa fa-check ai-language-check"></i>
          </div>
          <div class="ai-language-option" data-language="de">
            <span class="ai-language-option-label">Deutsch</span>
            <i class="fa fa-check ai-language-check"></i>
          </div>
          <div class="ai-language-option" data-language="ru">
            <span class="ai-language-option-label">Русский</span>
            <i class="fa fa-check ai-language-check"></i>
          </div>
          <div class="ai-language-option" data-language="ua">
            <span class="ai-language-option-label">Українська</span>
            <i class="fa fa-check ai-language-check"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="ai-chatbot-messages-wrap">
      <div class="ai-chatbot-messages" id="ai-messages-container">
        {{#messages}}
          <div class="ai-message ai-message--{{role}}">
            <div class="ai-message-bubble">
              <div class="ai-message-content">{{{content_html}}}</div>
              <div class="ai-message-time">{{created_at}}</div>
            </div>
          </div>
        {{/messages}}
      </div>

      <div class="ai-translating-overlay hidden" id="ai-translating-overlay"
          data-label-translating="{{#str}} translating, local_ai_system {{/str}}"
          data-label-loading="{{#str}} loading_original, local_ai_system {{/str}}">
        <div class="ai-translating-spinner"></div>
        <span id="ai-translating-label"></span>
      </div>
    </div>

    <div class="ai-chatbot-input-area">
      <div class="ai-input-row">
        <textarea id="ai-message-input"
                  class="ai-textarea"
                  rows="1"
                  placeholder="{{#str}} type_message, local_ai_system {{/str}}"
                  maxlength="4000"></textarea>
        <button id="ai-send-btn" class="ai-send-btn" aria-label="Send">
          <i class="fa fa-arrow-up"></i>
        </button>
        <button id="ai-stop-btn" class="ai-stop-btn" aria-label="Stop">
          <i class="fa fa-stop"></i>
        </button>
      </div>
    </div>
  </div>

  <div id="ai-rename-popup" class="ai-popup hidden">
    <div class="ai-popup-content">
      <h5>{{#str}} rename_chat_header, local_ai_system {{/str}}</h5>
      <input type="text" id="ai-rename-input" class="form-control">
      <div class="ai-popup-actions">
        <button id="ai-rename-save" class="btn btn-primary btn-sm">{{#str}} save_chat_name, local_ai_system {{/str}}</button>
        <button id="ai-rename-cancel" class="btn btn-secondary btn-sm">{{#str}} cancel_chat_name, local_ai_system {{/str}}</button>
      </div>
    </div>
  </div>
</div>
